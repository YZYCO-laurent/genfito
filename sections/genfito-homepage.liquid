<script>
  function genfitoToggleFaq(el) {
    var item = el.closest('.faq-item');
    var isOpen = item.classList.contains('open');
    document.querySelectorAll('.faq-item.open').forEach(function(i) { i.classList.remove('open'); });
    if (!isOpen) item.classList.add('open');
  }
  function genfitoToggleFaqExtra(el) {
    var extra = document.getElementById('faq-extra');
    var isOpen = el.classList.contains('open');
    el.classList.toggle('open');
    extra.classList.toggle('open');
  }
  function genfitoSetToggle(btn) {
    document.querySelectorAll('.offer-toggle-btn').forEach(function(b) { b.classList.remove('active'); });
    btn.classList.add('active');
    var isSubscribe = btn.textContent.trim().toUpperCase().indexOf('SUBSCRIBE') !== -1;
    var subCards = document.getElementById('offer-cards-subscribe');
    var oneCards = document.getElementById('offer-cards-onetime');
    if (subCards) subCards.style.display = isSubscribe ? 'grid' : 'none';
    if (oneCards) oneCards.style.display = isSubscribe ? 'none' : 'grid';
    var activeSet = isSubscribe ? subCards : oneCards;
    if (activeSet) {
      activeSet.querySelectorAll('.offer-card').forEach(function(c,i) {
        c.classList.toggle('selected', i === (isSubscribe ? 1 : 0));
      });
      var firstSelected = activeSet.querySelector('.offer-card.selected');
      if (firstSelected) {
        var link = firstSelected.getAttribute('onclick').match(/'([^']+)'/);
        if (link) document.getElementById('offer-main-cta').href = link[1];
      }
    }
  }
  function genfitoSelectOfferCard(card, url) {
    var parent = card.closest('.offer-cards');
    if (parent) {
      parent.querySelectorAll('.offer-card').forEach(function(c) {
        c.classList.remove('selected');
      });
    }
    card.classList.add('selected');
    var cta = document.getElementById('offer-main-cta');
    if (cta) cta.href = url;
  }

  document.addEventListener('DOMContentLoaded', function() {
    var defaultSelected = document.querySelector('#offer-cards-subscribe .offer-card.selected');
    if (defaultSelected) {
      var link = defaultSelected.getAttribute('onclick').match(/'([^']+)'/);
      var cta = document.getElementById('offer-main-cta');
      if (link && cta) cta.href = link[1];
    }
  });

  document.addEventListener('DOMContentLoaded', function() {
    if (typeof fbq !== 'undefined') {
      fbq('track', 'ViewContent', { content_name: 'Genfito Landing Page', content_category: 'Landing Page' });
    }
    document.querySelectorAll('a[href*="quiz.html"]').forEach(function(link) {
      link.addEventListener('click', function() {
        if (typeof fbq !== 'undefined') {
          fbq('trackCustom', 'QuizCTAClick', { content_name: 'Blood Sugar Quiz CTA' });
        }
      });
    });
    document.querySelectorAll('a[href*="vitruvin-gen.myshopify.com"], a[href*="myshopify.com"]').forEach(function(link) {
      link.addEventListener('click', function() {
        if (typeof fbq !== 'undefined') {
          fbq('track', 'InitiateCheckout', { content_name: 'Genfito Product', content_category: 'Supplement', num_items: 1 });
        }
      });
    });
  });
</script>
<script>
  function genfitoToggleMobileMenu() {
    var menu = document.getElementById('nav-mobile-menu');
    var btn = document.getElementById('nav-hamburger-btn');
    if (menu.classList.contains('open')) {
      menu.classList.remove('open');
      btn.setAttribute('aria-expanded', 'false');
    } else {
      menu.classList.add('open');
      btn.setAttribute('aria-expanded', 'true');
    }
  }
  function genfitoCloseMobileMenu() {
    var menu = document.getElementById('nav-mobile-menu');
    var btn = document.getElementById('nav-hamburger-btn');
    menu.classList.remove('open');
    btn.setAttribute('aria-expanded', 'false');
  }
  function genfitoNavScrollTo(e, id) {
    e.preventDefault();
    genfitoCloseMobileMenu();
    setTimeout(function() {
      var target = document.getElementById(id);
      if (!target) return;
      var navEl = document.querySelector('.genfito-hp nav');
      var navHeight = navEl ? navEl.offsetHeight : 0;
      var top = target.getBoundingClientRect().top + window.pageYOffset;
      window.scrollTo({ top: top, behavior: 'smooth' });
    }, 80);
  }
  document.addEventListener('click', function(e) {
    var menu = document.getElementById('nav-mobile-menu');
    var btn = document.getElementById('nav-hamburger-btn');
    if (menu && menu.classList.contains('open') && !menu.contains(e.target) && !btn.contains(e.target)) {
      menu.classList.remove('open');
      btn.setAttribute('aria-expanded', 'false');
    }
  });
</script>
<script>
  // ─── Authority Logo Carousel (mobile only) ───
  (function() {
    var slides = document.getElementById('authority-slides');
    var dots = document.querySelectorAll('.authority-dot');
    var total = 3;
    var current = 0;
    var autoTimer;

    function goTo(index) {
      current = (index + total) % total;
      if (slides) slides.style.transform = 'translateX(-' + (current * 100) + '%)';
      dots.forEach(function(d, i) {
        d.classList.toggle('active', i === current);
      });
    }

    dots.forEach(function(dot) {
      dot.addEventListener('click', function() {
        goTo(parseInt(this.getAttribute('data-slide'), 10));
        resetAuto();
      });
    });

    var touchStartX = 0;
    var carousel = document.getElementById('authority-carousel');
    if (carousel) {
      carousel.addEventListener('touchstart', function(e) {
        touchStartX = e.touches[0].clientX;
      }, { passive: true });
      carousel.addEventListener('touchend', function(e) {
        var dx = e.changedTouches[0].clientX - touchStartX;
        if (Math.abs(dx) > 40) {
          goTo(dx < 0 ? current + 1 : current - 1);
          resetAuto();
        }
      }, { passive: true });
    }

    function startAuto() {
      autoTimer = setInterval(function() { goTo(current + 1); }, 3000);
    }
    function resetAuto() {
      clearInterval(autoTimer);
      startAuto();
    }

    function initCarousel() {
      if (window.innerWidth <= 1024) {
        goTo(0);
        startAuto();
      }
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCarousel);
    } else {
      initCarousel();
    }
    window.addEventListener('resize', function() {
      clearInterval(autoTimer);
      if (window.innerWidth <= 1024) {
        goTo(current);
        startAuto();
      }
    });
  })();
</script>
